node_modules/
.env
.env.*
!.env.example

# Claude local project settings can contain machine-specific hook commands.
.claude/settings.local.json
# settings.json under .claude/ ends up listing absolute Windows paths and
# user-specific plugin/skill ids, so it's not portable to other clones.
.claude/settings.json

# Local runtime output
*.log
.claude-companion/

# Obsidian editor state
.obsidian/

# Private chat / scratch logs that shouldn't ship to public clones.
conversationWith*.md

# Documentation, examples, and Claude-agent-specific instructions —
# kept locally for reference, not shipped with the repo (the runtime
# only needs packages/ + scripts/ + package.json + package-lock.json).
docs/
examples/
CLAUDE.md

# Local scratch directory
.tmp/

# electron-builder output (release artifacts)
dist/

