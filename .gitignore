node_modules/
.env
.env.*
!.env.example

# Claude local project settings can contain machine-specific hook commands.
.claude/settings.local.json
# settings.json under .claude/ ends up listing absolute Windows paths and
# user-specific plugin/skill ids, so it's not portable to other clones.
.claude/settings.json

# Local runtime output
*.log
.claude-companion/

# Obsidian editor state
.obsidian/

# Private chat / scratch logs that shouldn't ship to public clones.
conversationWith*.md

# Design exploration / research artifacts — not loaded by the running app,
# kept locally for reference but not shipped with the repo.
docs/knowledge-cards-v*.html
docs/ui-redesign-*.html
docs/design-language-v*.html
docs/桌面宠物开源项目技术栈调研报告.md

# Local scratch directory
.tmp/
